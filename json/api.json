        },
        "message": {
            "2025-05-18T13:50:00": {
                "INCIDENT_STATUS_EN": "NEW",
                "INCIDENT_STATUS_CN": "最新情況",
                "ID": "115023",
                "CONTENT_EN": "Due to vessel mechanical defects, the following ferry service(s) will be or have been suspended. The last sailing(s) are: Fortune Ferry Company Limited North Point - Kwun Tong/Kai Tak: 1:00 pm Kwun Tong - Kai Tak: 12:15pm Kai Tak - Kwun Tong/North Point: 12:25 pm Kwun Tong - North Point: 12:35 pm",
                "CONTENT_CN": "因船隻機件故障，以下渡輪服務將會或已經暫停服務。 尾班船如下： 富裕小輪有限公司 北角-觀塘/啟德:下午01:00 觀塘-啟德:下午12:15 啟德-觀塘/北角:下午12:25 啟德-北角:下午12:35"
            },
            "2025-05-18T14:01:00": {
                "INCIDENT_STATUS_EN": "UPDATED",
                "INCIDENT_STATUS_CN": "更新情況",
                "ID": "115025",
                "CONTENT_EN": "Due to vessel mechanical defects, the following ferry service has been suspended. \nFortune Ferry Company Limited\n-North Point - Kwun Tong - Kai Tak \n-Kai Tak - Kwun Tong - North Point.",
                "CONTENT_CN": "因船隻機件故障，以下渡輪服務已經暫停服務。\n富裕小輪有限公司\n-北角-觀塘-啟德\n-啟德-觀塘-北角。"
            },
            "2025-05-18T15:08:00": {
                "INCIDENT_STATUS_EN": "UPDATED",
                "INCIDENT_STATUS_CN": "更新情況",
                "ID": "115027",
                "CONTENT_EN": "The following ferry services which was suspended due to vessel mechanical defects will be resumed:\nFortune Ferry Company Limited\n-North Point - Kwun Tong - Kai Tak : resumes at 05:00 pm\n-Kai Tak - Kwun Tong - North Point : resumes at 05:25 pm.",
                "CONTENT_CN": "較早前因受船隻機件故障而停航的以下渡輪服務將會恢復服務:\n富裕小輪有限公司\n-北角-觀塘-啟德:下午05時00分恢復\n-啟德-觀塘-北角:下午05時25分恢復。"
            }
        },
        "district": null,
        "last_update": "2025-05-18T15:22:46",
        "last_announcement": "2025-05-18T15:08:00"
    },
